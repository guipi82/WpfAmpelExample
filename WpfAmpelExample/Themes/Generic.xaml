<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:WpfAmpelExample.Controls">

    <Style x:Key="AmpelControlStyle" TargetType="{x:Type controls:AmpelControl}">
        <Style.Setters>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:AmpelControl}">
                        <StackPanel>
                            <Ellipse x:Name="Light1"
                                     Width="100"
                                     Height="100"
                                     Fill="Gray" />
                            <Ellipse x:Name="Light2"
                                     Width="100"
                                     Height="100"
                                     Fill="Gray" />
                            <Ellipse x:Name="Light3"
                                     Width="100"
                                     Height="100"
                                     Fill="Gray" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="AktuellesAmpelLicht" Value="Red">
                                <Setter TargetName="Light1" Property="Fill" Value="Red" />
                            </Trigger>
                            <Trigger Property="AktuellesAmpelLicht" Value="Yellow">
                                <Setter TargetName="Light2" Property="Fill" Value="Yellow" />
                            </Trigger>
                            <Trigger Property="AktuellesAmpelLicht" Value="Green">
                                <Setter TargetName="Light3" Property="Fill" Value="Green" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>
    </Style>

</ResourceDictionary>

